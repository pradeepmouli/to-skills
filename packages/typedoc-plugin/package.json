{
  "name": "typedoc-plugin-to-skills",
  "version": "1.2.2",
  "description": "TypeDoc plugin that generates AI agent skills (SKILL.md) and llms.txt — auto-discovered by TypeDoc",
  "keywords": [
    "agent-skills",
    "ai",
    "claude-code",
    "cli",
    "copilot",
    "cursor",
    "documentation",
    "jsdoc",
    "llm",
    "llms-txt",
    "skill-md",
    "to-skills",
    "typedoc",
    "typedoc-plugin",
    "typescript"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pradeepmouli/to-skills.git",
    "directory": "packages/typedoc-plugin"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/pradeepmouli"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "scripts": {
    "build": "tsgo -p tsconfig.build.json",
    "type-check": "tsgo --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@to-skills/typedoc": "workspace:*"
  },
  "peerDependencies": {
    "typedoc": ">=0.28.0"
  }
}
