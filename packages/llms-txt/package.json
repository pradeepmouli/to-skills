{
  "name": "@to-skills/llms-txt",
  "version": "0.1.0",
  "description": "TypeDoc plugin that generates llms.txt and llms-full.txt following the llmstxt.org specification",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "keywords": [
    "typedoc",
    "typedoc-plugin",
    "llms-txt",
    "llms",
    "ai",
    "documentation"
  ],
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsgo -p tsconfig.build.json",
    "type-check": "tsgo --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@to-skills/core": "workspace:*"
  },
  "peerDependencies": {
    "typedoc": ">=0.28.0"
  },
  "devDependencies": {
    "typedoc": "^0.28.17"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pradeepmouli/to-skills.git",
    "directory": "packages/llms-txt"
  }
}
