{
  "name": "to-skills",
  "version": "0.0.0",
  "private": true,
  "description": "Compile inline documentation into AI agent skills. Your code is the source of truth.",
  "license": "MIT",
  "author": "Pradeep Mouli",
  "repository": {
    "type": "git",
    "url": "https://github.com/pradeepmouli/to-skills.git"
  },
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "build": "pnpm -r run build",
    "dev": "vitest",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "type-check": "pnpm -r run type-check",
    "clean": "pnpm -r run clean",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "pnpm run build && changeset publish",
    "audit": "pnpm audit --audit-level moderate",
    "outdated": "pnpm outdated -r",
    "update:deps": "pnpm update -r --latest",
    "prepare": "simple-git-hooks",
    "docs": "typedoc --out docs/html --plugin typedoc-plugin-to-skills",
    "docs:md": "typedoc"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@types/node": "^25.6.0",
    "@typescript/native-preview": "7.0.0-dev.20260414.1",
    "@vitest/coverage-v8": "^4.1.4",
    "lint-staged": "^16.4.0",
    "oxlint": "^1.60.0",
    "simple-git-hooks": "^2.13.1",
    "typedoc": "^0.28.19",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged",
    "pre-push": "pnpm run type-check"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "oxfmt",
      "oxlint --fix"
    ],
    "*.{json,md}": [
      "oxfmt --no-error-on-unmatched-pattern"
    ]
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.6.2"
}
